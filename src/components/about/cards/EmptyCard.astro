---
import "../../../globals.css";
import GitHubButton from "../../buttons/GitHubButton.astro";
---

<div class="relative flex w-80 flex-col rounded-xl bg-white bg-clip-border text-gray-700 shadow-md">
  <div id="back" class="relative mx-4 -mt-6 h-40 overflow-hidden rounded-xl bg-blue-gray-500 bg-clip-border text-white shadow-lg shadow-blue-gray-500/40 bg-gradient-to-r from-blue-500 to-blue-600">
  </div>
  <div class="p-6">
    <h5 class="mb-2 block font-sans text-xl font-semibold leading-snug tracking-normal text-blue-gray-900 antialiased">
     Carta vacia
    </h5>
    <p class="block font-sans text-base font-light leading-relaxed text-inherit antialiased">
   Esta carta está vacia simplemente para rellenar espacio en mi porfolio, pero aquí irán algunos de mis proyectos
    </p>
  </div>
  <div class="p-6 pt-0">
    <GitHubButton id="botonazo" context="Ver en GitHub" />
  </div>
</div>

<style>
  #back {
    background-color: cyan;
    background-position: center;
    background-size: cover;
  }
</style>